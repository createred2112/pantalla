{
  "name": "pantalla",
  "version": "0.152.0",
  "description": "Motor de cartelería digital para LA PANTALLA (gasteizberri): genera MP4 con texto/foto variables, importa piezas de vídeo, prepara siempre ocho vídeos con nombres fijos y sube por FTP sobreescribiendo. Incluye panel móvil de admin, logs y status.",
  "type": "commonjs",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "publish": "node src/cli.js publish",
    "generate": "node src/cli.js generate",
    "sequence": "node src/cli.js sequence",
    "upload": "node src/cli.js upload",
    "import": "node src/cli.js import",
    "demo": "node src/cli.js demo",
    "admin:add": "node src/cli.js admin:add",
    "admin:remove": "node src/cli.js admin:remove",
    "admin:list": "node src/cli.js admin:list",
    "qa:templates": "node scripts/qa-template-matrix.js",
    "qa:templates:visual": "node scripts/qa-template-matrix.js --render",
    "qa:rundown-order": "node scripts/qa-rundown-order.js",
    "backup": "node src/cli.js backup",
    "backup:restore": "node src/cli.js backup:restore",
    "qa:backup": "node scripts/qa-backup.js",
    "qa:pipeline-lock": "node scripts/qa-pipeline-lock.js",
    "qa:render-close": "node scripts/qa-html-render-close.js",
    "qa:takeover": "node scripts/qa-takeover-retry.js",
    "qa:autofit": "node scripts/qa-autofit.js",
    "qa:agenda": "node scripts/qa-agenda.js",
    "qa:ui-copy": "node scripts/qa-ui-copy.js",
    "qa:docs": "node scripts/qa-docs.js",
    "manual:capturas": "playwright test -c playwright.manual.config.js",
    "qa:e2e": "playwright test",
    "qa:visual:baseline": "node scripts/qa-visual-diff.js --baseline",
    "qa:visual:check": "node scripts/qa-visual-diff.js",
    "test": "npm run qa:rundown-order && npm run qa:backup && npm run qa:pipeline-lock && npm run qa:render-close && npm run qa:takeover && npm run qa:templates && npm run qa:autofit && npm run qa:agenda && npm run qa:ui-copy && npm run qa:docs && npm run qa:e2e && npm run qa:visual:check"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0"
  },
  "dependencies": {
    "basic-ftp": "^5.0.5",
    "web-push": "^3.6.7",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.3.0",
    "multer": "^2.0.0",
    "puppeteer": "^25.2.1",
    "sharp": "^0.33.4"
  }
}
