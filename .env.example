# --- FTP de la pantalla ---
# Copia este fichero a .env y rellena con los datos reales del VPS/cartel.
FTP_HOST=ftp.tu-servidor.com
FTP_PORT=21
FTP_USER=usuario
FTP_PASSWORD=contraseña
# FTPS explícito (recomendado si el servidor lo soporta): true / false
FTP_SECURE=false

# --- Servidor del panel de admin ---
PORT=8080
# Secreto para firmar las cookies de sesión. Si lo dejas vacío se genera uno
# y se guarda en data/.session-secret. Defínelo en producción para fijarlo.
SESSION_SECRET=
# Token de máquina opcional (para automatizaciones: cron, worker de codex…).
# Permite llamar a /api/* con la cabecera x-panel-token o ?token=... SIN sesión.
# Los administradores humanos entran por usuario/contraseña, no con esto.
PANEL_TOKEN=
